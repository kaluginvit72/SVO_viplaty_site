# Пример `.env` рядом с `docker-compose.yml` на VPS.
# Скопируйте: cp deploy/env.production.example .env && chmod 600 .env

# Обязательно для docker-compose.yml (namespace образа в GHCR, только строчные буквы)
GHCR_IMAGE_OWNER=kaluginvit72

NODE_ENV=production
PORT=3000

# Публичный URL без завершающего слэша (OG, canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://svorazbor.ru

# Аналитика (опционально; см. web/README.md)
# На VPS без пересборки образа задайте рантайм-имена (дублируйте значения счётчиков):
GA_MEASUREMENT_ID=
YM_COUNTER_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Вебхук заявки (n8n / Make / свой URL). Без LEAD_WEBHOOK_URL отправка на вебхук не выполняется.
LEAD_WEBHOOK_URL=
# Опционально: Authorization: Bearer … для проверки на приёмнике
LEAD_WEBHOOK_SECRET=

CONTACT_TEXT=

LEADS_STORAGE_MODE=file
LEADS_FILE_PATH=./data/leads.json
